\frametitle{核心优化模块分点演示}
\begin{lstlisting}
from arm_agent.langgraph_orchestrator import LangGraphEnhancedOrchestrator
from tools.pdf_parser_tools import parse_pdf_document
from arm_agent.evaluation_engine import compute_claim_metrics
from arm_agent.security_audit import SecurityAuditLogger
from tools.multi_literature_fusion import fuse_arm_assets
\end{lstlisting}
  \begin{itemize}
    \item \textbf{LangGraph断点续跑编排：}标准化JSON checkpoint持久化会话，批量论文中途中断无需从头执行，原生落地长流程Agent状态持久化方案，支持人工审批暂停节点；保障长流程任务的极高稳定性。
    \item \textbf{全格式PDF解析插件：}pdfplumber主解析搭配PyPDF2兼容兜底双解析引擎，自动提取图表、表格图注并绑定原文evidence证据链，彻底解决传统系统仅支持TXT输入的局限，完美适配真实脑科学科研论文场景。
    \item \textbf{专业量化评测引擎：}自动批量计算精确率/召回率/F1质量指标，逐句逐段比对原文生成幻觉统计报表，将文献调研中"杜绝模型编造无依据内容"的理论要求完整落地为可自动化运行的校验代码，提供稀缺的量化质控方案。
    \item \textbf{完整安全审计体系：}前置输入恶意Prompt防护网关、全链路完整结论溯源链、API耗时与Token消耗全量记录归档，完整落地输入/工具/输出三层安全约束规则，安全规范对标开源仓库风控模块实现。
    \item \textbf{多源文献融合引擎：}自动术语归一对齐、冲突结论智能标记、可信度加权打分，原生对接PubMed官方真实检索接口，自动补充论文外部佐证文献，实现多源证据交叉验证，提供强大的高阶多文献处理能力。
  \end{itemize}
